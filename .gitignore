# ----------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.local
.env.*.local
secrets.toml
*.secret

# ----------------------------
