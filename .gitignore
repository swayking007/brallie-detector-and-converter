# ----------------------------
datasets/raw/
datasets/cache/
datasets/*.zip
datasets/*.tar.gz
*.cache
.cache/
__pycache__/

# ----------------------------
# Jupyter Notebooks
# ----------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------
# Streamlit
# ----------------------------
.streamlit/secrets.toml

# ----------------------------
